{
  "name": "n8n-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo scaffold for web, api, worker and shared packages.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "npm run --workspace @n8n/web lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run --workspace @n8n/web typecheck",
    "test": "npm run --workspace @n8n/web test && node --test",
    "build": "npm run --workspace @n8n/web build",
    "prepare": "husky",
    "start:security-baseline": "node src/server.js",
    "check": "node --check src/server.js && node --check src/auth/service.js && node --check src/security/rbac.js && node --check src/security/secrets.js && node --check src/security/audit.js",
    "web:dev": "npm run --workspace @n8n/web dev",
    "web:build": "npm run --workspace @n8n/web build",
    "web:check": "npm run --workspace @n8n/web check"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "otplib": "^12.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.5.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
